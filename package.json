{
  "name": "swagger-ui-cli",
  "version": "0.0.11",
  "main": "dist/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "swagger-ui-cli": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.js && tsc --emitDeclarationOnly -p ./tsconfig.app.json --outDir ./dist",
    "format": "prettier --write '**/*.{html,js,json,md,scss,ts}'",
    "format:check": "prettier --check '**/*.{html,js,json,md,scss,ts}'",
    "lint": "eslint . --ext .js,.ts --fix",
    "lint:check": "eslint . --ext .js,.ts",
    "test": "npm run build && cypress run",
    "test:dev": "npm run build && cypress open",
    "test:custom": "npm run build && tsx test.ts",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szendezsombor/swagger-ui-cli.git"
  },
  "keywords": [],
  "author": "Zsombor Szende",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/szendezsombor/swagger-ui-cli/issues"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "public/**/*",
    "Readme.md",
    "LICENSE"
  ],
  "homepage": "https://github.com/szendezsombor/swagger-ui-cli#readme",
  "description": "This is a CLI tool bundle your openapi documentation or serve for live editing.",
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "@types/signale": "^1.4.7",
    "@types/swagger-ui": "^5.21.1",
    "cli-testing-library": "^3.0.1",
    "cypress": "^14.5.2",
    "esbuild": "^0.25.5",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "execa": "9.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "prettier": "^3.5.3",
    "puppeteer": "^24.10.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "signale": "^1.4.0",
    "swagger-ui": "^5.24.0",
    "vite": "^6.3.5",
    "vite-plugin-singlefile": "^2.2.0"
  }
}
